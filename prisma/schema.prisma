generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Log {
  id        Int      @id @default(autoincrement())
  action    String
  chatId    String?
  phone     String?
  authorId  String?
  targetId  String?
  messageId String?
  content   String?  @db.Text
  details   String?  @db.LongText
  createdAt DateTime @default(now())

  @@map("logs")
}
