generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Log {
  id        Int      @id @default(autoincrement())
  action    String
  chatId    String?
  phone     String?
  authorId  String?
  targetId  String?
  messageId String?
  content   String?  @db.Text
  details   String?  @db.LongText
  createdAt DateTime @default(now())

  @@map("logs")
}

model OraclePrediction {
  id        Int      @id @default(autoincrement())
  phone     String
  weekKey   String
  message   String   @db.Text
  luckType  String   @default("SORTE")
  luckyNumber Int    @default(0)
  animalName String?
  createdAt DateTime @default(now())

  @@unique([phone, weekKey])
  @@map("oracle_predictions")
}

model PowerAnimal {
  id          Int      @id @default(autoincrement())
  name        String
  description String   @db.Text
  habitat     String?
  createdAt   DateTime @default(now())

  @@map("power_animals")
}
